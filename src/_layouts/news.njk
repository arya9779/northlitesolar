---
layout: "base.njk"
---
<main class="pt-[72px] md:pt-[80px] bg-background">

    <!-- Hero Section -->
    <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-16 reveal">
        <div class="relative w-full h-[40vh] md:h-[50vh] rounded-sm overflow-hidden border border-outline-variant/30">
            <img alt="{{ title }} Hero Image" class="absolute inset-0 w-full h-full object-cover" src="{{ hero.image }}"/>
            <div class="absolute inset-0 bg-slate-deep/60 flex items-center justify-center p-6 md:p-8">
                <div class="text-center max-w-3xl">
                    <h1 class="font-display-lg text-headline-lg-mobile md:text-display-lg text-pure-white mb-4 leading-tight font-bold tracking-tight">
                        {{ hero.title }}
                    </h1>
                    <p class="font-body-lg text-body-lg text-secondary-fixed-dim/90">
                        {{ hero.subtitle }}
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Intro Section -->
    <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-20 reveal">
        <div class="bg-pure-white rounded-sm p-8 md:p-12 border border-outline-variant/30 text-center max-w-4xl mx-auto">
            <span class="material-symbols-outlined text-primary text-5xl mb-4 block" style="font-variation-settings: 'FILL' 1;">article</span>
            <h2 class="font-headline-lg text-headline-lg text-slate-deep mb-6 font-bold">{{ intro.heading }}</h2>
            <p class="font-body-lg text-body-lg text-secondary leading-relaxed">
                {{ intro.body }}
            </p>
        </div>
    </section>

    <!-- Articles Section -->
    <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-24">
        <div class="mb-16 text-center reveal">
            <span class="font-mono text-xs text-primary uppercase tracking-widest mb-3 block">Publications</span>
            <h2 class="font-headline-lg text-3xl md:text-headline-lg text-slate-deep font-bold">{{ articles.title }}</h2>
        </div>

        <div class="tech-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
            {% for article in articles.list %}
            <div class="tech-grid-cell flex flex-col justify-start">
                <!-- Metadata: Date and Author -->
                <div class="flex items-center gap-4 text-xs text-secondary font-mono mb-4 border-b border-outline-variant/10 pb-3">
                    <div class="flex items-center gap-1.5 font-semibold text-primary">
                        <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                        <span>{{ article.published }}</span>
                    </div>
                    <div class="w-1 h-1 bg-outline-variant/30 rounded-full"></div>
                    <div class="flex items-center gap-1.5">
                        <span class="material-symbols-outlined text-[14px]">person</span>
                        <span>{{ article.author }}</span>
                    </div>
                </div>

                <!-- Title & Summary -->
                <h3 class="font-headline-md text-slate-deep mb-4 text-[20px] font-bold leading-snug">
                    {{ article.title }}
                </h3>
                <p class="font-body-md text-body-md text-secondary leading-relaxed mb-8 flex-grow">
                    {{ article.summary }}
                </p>

                <!-- Read more link -->
                <div class="mt-auto pt-4 border-t border-outline-variant/10 flex items-center justify-between text-primary font-mono text-xs uppercase tracking-wider group/link cursor-pointer">
                    <span class="font-bold">Read Article</span>
                    <span class="material-symbols-outlined text-[20px] transition-transform duration-300 group-hover/link:translate-x-1.5">arrow_right_alt</span>
                </div>
            </div>
            {% endfor %}
        </div>
    </section>

    <!-- Press CTA Section -->
    <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-24 reveal">
        <div class="relative bg-slate-deep text-pure-white rounded-sm p-8 md:p-12 border border-outline-variant/30 text-center">
            <div class="relative z-10 max-w-2xl mx-auto flex flex-col items-center">
                <span class="material-symbols-outlined text-primary-fixed text-5xl mb-6">chat</span>
                <p class="font-headline-md text-[20px] md:text-[24px] text-pure-white mb-8 leading-relaxed">
                    {{ cta.text }}
                </p>
                <a href="mailto:{{ cta.email }}" class="bg-primary text-pure-white font-mono text-xs uppercase tracking-wider px-8 py-4 rounded-sm hover:bg-slate-800 transition-all flex items-center space-x-2 border border-primary font-bold">
                    <span>Email Press Team</span>
                    <span class="material-symbols-outlined text-[20px]">mail</span>
                </a>
            </div>
        </div>
    </section>

</main>
