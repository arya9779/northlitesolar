---
layout: "base.njk"
---
<main class="pt-[72px] md:pt-[80px]">

    <!-- Hero Section -->
    <section class="relative h-[45vh] min-h-[400px] flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img alt="Solar Power Installation Roof" class="w-full h-full object-cover object-center hero-zoom" src="{{ hero.image }}"/>
            <div class="absolute inset-0 bg-slate-deep/75"></div>
        </div>
        <div class="relative z-10 text-center px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto reveal pt-16 md:pt-20">
            <p class="font-label-caps text-label-caps text-primary-fixed uppercase tracking-wider mb-4">{{ hero.tagline }}</p>
            <h1 class="font-display-lg text-headline-lg-mobile md:text-display-lg text-pure-white mb-6 max-w-4xl mx-auto leading-tight">{{ hero.title }}</h1>
            <p class="font-body-lg text-body-lg text-surface-variant max-w-2xl mx-auto">{{ hero.description }}</p>
        </div>
    </section>

    <!-- Solutions Switcher -->
    <section class="py-20 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto" id="solutions">
        <div class="text-center mb-16 reveal">
            <h2 class="font-headline-lg text-headline-lg text-slate-deep mb-4">{{ switcher.title }}</h2>
            <p class="font-body-md text-body-md text-secondary max-w-2xl mx-auto">{{ switcher.description }}</p>
        </div>
        
        <!-- Tabs Menu -->
        <div class="flex overflow-x-auto no-scrollbar whitespace-nowrap border-b border-outline-variant/30 mb-12 reveal lg:justify-center justify-start" id="solutions-tabs">
            {% for tab in switcher.tabs %}
            <button class="px-6 md:px-8 py-4 font-button text-[15px] md:text-button {% if loop.first %}tab-active{% else %}tab-inactive{% endif %} border-b-2 font-bold transition-all duration-300 flex-shrink-0" id="btn-{{ tab.id }}" onclick="switchTab('{{ tab.id }}')">{{ tab.name }}</button>
            {% endfor %}
        </div>

        <!-- Tab Content Wrapper (for fluid transition height) -->
        <div class="tab-content-wrapper min-h-[450px]">
            {% for tab in switcher.tabs %}
            <!-- Tab Content ({{ tab.name }}) -->
            <div class="tab-content tab-pane {% if loop.first %}active-pane{% else %}hidden{% endif %} flex flex-col gap-12 reveal" id="{{ tab.id }}">
                <div class="grid md:grid-cols-2 gap-gutter items-center">
                    <div class="order-2 md:order-1">
                        <h3 class="font-headline-md text-headline-md text-slate-deep mb-4">{{ tab.title }}</h3>
                        <p class="font-body-lg text-body-lg text-secondary mb-6 leading-relaxed">
                            {{ tab.description }}
                        </p>
                        {% if tab.points %}
                        <ul class="space-y-4 mb-8">
                            {% for pt in tab.points %}
                            <li class="flex items-start gap-3">
                                <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                                <span class="text-on-surface-variant font-medium">{{ pt }}</span>
                            </li>
                            {% endfor %}
                        </ul>
                        {% endif %}
                        <div class="flex gap-4">
                            <a href="/contact" class="bg-primary-container text-slate-deep font-button text-button px-6 py-3 rounded-lg hover-scale inline-block shadow-sm btn-magnetic">
                                Get a Quote
                            </a>
                        </div>
                    </div>
                    <div class="order-1 md:order-2 rounded-2xl overflow-hidden shadow-lg h-[300px] md:h-[450px]">
                        <img alt="{{ tab.title }}" class="w-full h-full object-cover" src="{{ tab.image }}"/>
                    </div>
                </div>

                {% if tab.benefits %}
                <!-- Bottom section: Core Benefits & Features -->
                <div>
                    <h4 class="font-label-caps text-label-caps text-primary mb-8 tracking-widest uppercase text-center">Core Benefits &amp; Features</h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                        {% for benefit in tab.benefits %}
                        <div class="glass-card border border-outline-variant/40 rounded-2xl p-6 hover-scale flex flex-col shadow-sm spotlight-card">
                            <div class="w-10 h-10 rounded-lg bg-secondary-container flex items-center justify-center text-on-tertiary-container mb-4">
                                <span class="material-symbols-outlined text-[20px]">{{ benefit.icon }}</span>
                            </div>
                            <h5 class="font-headline-md text-slate-deep mb-2 text-[18px]">{{ benefit.title }}</h5>
                            <p class="font-body-md text-body-md text-secondary text-sm leading-relaxed">{{ benefit.description }}</p>
                        </div>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </section>

    <!-- Services Grid (Bento/Glassmorphism influence) -->
    <section class="bg-surface-container-lowest py-20 border-y border-outline-variant/30">
        <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
            <div class="text-center mb-16 reveal">
                <h2 class="font-headline-lg text-headline-lg text-slate-deep mb-4">{{ services.title }}</h2>
                <p class="font-body-md text-body-md text-secondary max-w-2xl mx-auto">{{ services.description }}</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for svc in services.list %}
                {% if svc.special %}
                <!-- Special Big Feature Card -->
                <div class="glass-card border border-primary-container/30 rounded-2xl hover-scale flex flex-col h-full bg-slate-deep relative overflow-hidden group reveal shadow-[0_12px_40px_rgba(30,41,59,0.15)] spotlight-card lg:row-span-2 min-h-[450px]">
                    <img class="absolute inset-0 w-full h-full object-cover opacity-40 transition-transform duration-700 ease-out group-hover:scale-105" alt="{{ svc.title }}" src="{{ svc.image }}"/>
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-deep via-slate-deep/85 to-slate-deep/40"></div>
                    <div class="relative z-10 flex flex-col h-full p-8 md:p-10 justify-between">
                        <div>
                            <div class="flex items-center justify-between mb-8">
                                <div class="w-12 h-12 rounded-xl bg-primary-container/20 backdrop-blur-md flex items-center justify-center border border-primary-container/30">
                                    <span class="material-symbols-outlined text-primary-container text-2xl" style="font-variation-settings: 'FILL' 1;">{{ svc.icon }}</span>
                                </div>
                                <span class="font-label-caps text-label-caps text-primary-container bg-primary-container/10 px-3 py-1 rounded-full text-[10px] border border-primary-container/20 uppercase tracking-widest">{{ svc.badge }}</span>
                            </div>
                            <h3 class="font-headline-md text-pure-white mb-4 text-[24px] tracking-tight">{{ svc.title }}</h3>
                            <p class="font-body-md text-body-md text-surface-variant/80 leading-relaxed mb-6">
                                {{ svc.description }}
                            </p>
                        </div>
                        <div class="flex items-center justify-between pt-6 border-t border-pure-white/10 mt-auto">
                            <span class="font-label-caps text-[11px] text-primary-container/80 tracking-wider font-mono">{{ svc.status }}</span>
                            <div class="flex items-center gap-1.5 text-xs text-pure-white/60 bg-pure-white/5 px-2.5 py-1 rounded-md border border-pure-white/5">
                                <span class="w-2 h-2 rounded-full bg-eco-growth animate-pulse"></span>
                                <span>{{ svc.audit }}</span>
                            </div>
                        </div>
                    </div>
                </div>
                {% else %}
                <!-- Regular Service Card -->
                <div class="glass-card border border-outline-variant/40 rounded-2xl p-8 hover-scale flex flex-col h-full bg-surface-container-lowest/80 reveal shadow-[0_4px_20px_rgba(50,64,89,0.02)] spotlight-card">
                    <div class="w-12 h-12 rounded-lg bg-secondary-fixed flex items-center justify-center mb-6">
                        <span class="material-symbols-outlined text-on-secondary-fixed-variant" style="font-variation-settings: 'FILL' 1;">{{ svc.icon }}</span>
                    </div>
                    <h3 class="font-headline-md text-slate-deep mb-3 text-[20px]">{{ svc.title }}</h3>
                    <p class="font-body-md text-body-md text-secondary mb-6 flex-grow">{{ svc.description }}</p>
                    {% if svc.image %}
                    <div class="w-full h-44 rounded-lg overflow-hidden mt-auto">
                        <img class="w-full h-full object-cover" alt="{{ svc.title }}" src="{{ svc.image }}"/>
                    </div>
                    {% endif %}
                </div>
                {% endif %}
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Delivery Process Timeline -->
    <section class="py-20 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
        <div class="text-center mb-16 reveal">
            <h2 class="font-headline-lg text-headline-lg text-slate-deep mb-4">{{ timeline.title }}</h2>
            <p class="font-body-md text-body-md text-secondary max-w-2xl mx-auto">{{ timeline.description }}</p>
        </div>
        
        <div class="max-w-3xl mx-auto relative pl-12 md:pl-0">
            <div class="absolute left-6 md:left-[50%] top-0 bottom-0 w-0.5 bg-outline-variant/50 -translate-x-1/2"></div>
            
            <div class="space-y-12 relative z-10">
                {% for step in timeline.steps %}
                <div class="flex flex-col md:flex-row items-start md:items-center timeline-step relative reveal">
                    <div class="md:w-1/2 md:pr-12 {% if loop.index0 % 2 == 0 %}md:text-right{% endif %} flex-1">
                        <h3 class="font-headline-md text-headline-md text-slate-deep mb-2">{{ step.number }}. {{ step.title }}</h3>
                        <p class="font-body-md text-body-md text-secondary">{{ step.description }}</p>
                    </div>
                    <div class="w-12 h-12 rounded-full bg-slate-deep text-pure-white flex items-center justify-center flex-shrink-0 absolute left-[-48px] md:left-1/2 -translate-x-1/2 border-4 border-surface shadow-sm {% if loop.index0 % 2 != 0 %}bg-surface text-slate-deep ring-1 ring-outline-variant{% endif %} {% if step.highlight %}bg-primary-container text-on-primary-container{% endif %}">
                        <span class="material-symbols-outlined text-[22px]">{{ step.icon }}</span>
                    </div>
                    <div class="md:w-1/2 flex-1 hidden md:block"></div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>
</main>

<script>
    function switchTab(tabId) {
        const activeClass = 'tab-active';
        const inactiveClass = 'tab-inactive';
        
        const wrapper = document.querySelector('.tab-content-wrapper');
        const currentActivePane = document.querySelector('.tab-content:not(.hidden)');
        const nextPane = document.getElementById(tabId);
        
        if (!nextPane || currentActivePane === nextPane) return;
        
        document.querySelectorAll('#solutions-tabs button').forEach(button => {
            button.classList.remove(activeClass);
            button.classList.add(inactiveClass);
        });
        const activeBtn = document.getElementById(`btn-${tabId}`);
        if (activeBtn) {
            activeBtn.classList.remove(inactiveClass);
            activeBtn.classList.add(activeClass);
        }

        wrapper.style.transition = 'height 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
        wrapper.style.willChange = 'height';

        if (currentActivePane) {
            const currentHeight = wrapper.offsetHeight;
            wrapper.style.height = currentHeight + 'px';
            void wrapper.offsetHeight;

            currentActivePane.classList.remove('active-pane');
            currentActivePane.classList.add('hidden');
        }

        nextPane.classList.remove('hidden');
        const targetHeight = nextPane.offsetHeight;

        wrapper.style.height = targetHeight + 'px';

        setTimeout(() => {
            nextPane.classList.add('active-pane');
        }, 50);

        const handleTransitionEnd = (e) => {
            if (e.target === wrapper && e.propertyName === 'height') {
                wrapper.style.height = 'auto';
                wrapper.style.transition = '';
                wrapper.style.willChange = '';
                wrapper.removeEventListener('transitionend', handleTransitionEnd);
            }
        };
        wrapper.addEventListener('transitionend', handleTransitionEnd);
    }

    function initTabFromUrl() {
        const urlParams = new URLSearchParams(window.location.search);
        const tabParam = urlParams.get('tab');
        const validTabs = ['on-grid', 'off-grid', 'zero-invest', 'commercial'];
        
        if (tabParam && validTabs.includes(tabParam)) {
            setTimeout(() => {
                switchTab(tabParam);
            }, 50);
        }
    }

    if (document.readyState === 'loading') {
        window.addEventListener('DOMContentLoaded', initTabFromUrl);
    } else {
        initTabFromUrl();
    }
</script>
