---
layout: "base.njk"
---
<main class="pt-[72px] md:pt-[80px] bg-background">

    <!-- Hero Section -->
    <section class="relative h-[40vh] min-h-[350px] flex items-center justify-center overflow-hidden border-b border-outline-variant/20">
        <div class="absolute inset-0 z-0">
            <img alt="Solar Power Installation Roof" class="w-full h-full object-cover object-center" src="{{ hero.image }}"/>
            <div class="absolute inset-0 bg-slate-deep/75"></div>
        </div>
        <div class="relative z-10 text-center px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto reveal pt-16 md:pt-20">
            <p class="font-mono text-xs text-primary uppercase tracking-widest mb-4">{{ hero.tagline }}</p>
            <h1 class="font-display-lg text-headline-lg-mobile md:text-[48px] text-pure-white mb-6 max-w-4xl mx-auto leading-tight font-bold tracking-tight">{{ hero.title }}</h1>
            <p class="font-body-lg text-body-md text-surface-variant max-w-2xl mx-auto leading-relaxed">{{ hero.description }}</p>
        </div>
    </section>

    <!-- Solutions Switcher -->
    <section class="py-20 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto" id="solutions">
        <div class="mb-16 reveal">
            <span class="font-mono text-xs text-primary uppercase tracking-widest mb-3 block">01 // Engineering Specs</span>
            <h2 class="font-headline-lg text-3xl md:text-headline-lg text-slate-deep font-bold">{{ switcher.title }}</h2>
            <p class="font-body-md text-body-md text-secondary max-w-2xl mt-4 leading-relaxed">{{ switcher.description }}</p>
        </div>
        
        <!-- Tabs Menu -->
        <div class="flex overflow-x-auto no-scrollbar whitespace-nowrap border-b border-outline-variant/30 mb-12 reveal justify-start" id="solutions-tabs">
            {% for tab in switcher.tabs %}
            <button class="px-6 md:px-8 py-4 font-mono text-xs uppercase tracking-wider {% if loop.first %}tab-active{% else %}tab-inactive{% endif %} font-bold transition-all flex-shrink-0" id="btn-{{ tab.id }}" onclick="switchTab('{{ tab.id }}')">{{ tab.name }}</button>
            {% endfor %}
        </div>

        <!-- Tab Content Wrapper -->
        <div class="tab-content-wrapper min-h-[450px]">
            {% for tab in switcher.tabs %}
            <!-- Tab Content ({{ tab.name }}) -->
            <div class="tab-content tab-pane {% if loop.first %}active-pane{% else %}hidden{% endif %} flex flex-col gap-12 reveal" id="{{ tab.id }}">
                <div class="grid md:grid-cols-2 gap-12 items-center">
                    <div class="order-2 md:order-1">
                        <h3 class="font-headline-md text-2xl text-slate-deep mb-4 font-bold">{{ tab.title }}</h3>
                        <p class="font-body-lg text-sm text-secondary mb-6 leading-relaxed">
                            {{ tab.description }}
                        </p>
                        {% if tab.points %}
                        <ul class="space-y-3 mb-8">
                            {% for pt in tab.points %}
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary text-lg mt-0.5">check_circle</span>
                                <span class="text-secondary text-sm leading-relaxed">{{ pt }}</span>
                            </li>
                            {% endfor %}
                        </ul>
                        {% endif %}
                        <div class="flex gap-4">
                            <a href="/contact" class="bg-primary text-pure-white font-mono text-xs uppercase tracking-wider px-6 py-3 rounded-sm hover:bg-slate-deep transition-all">
                                Get a Quote
                            </a>
                        </div>
                    </div>
                    <div class="order-1 md:order-2 border border-outline-variant/30 h-[300px] md:h-[400px] overflow-hidden rounded-sm">
                        <img alt="{{ tab.title }}" class="w-full h-full object-cover" src="{{ tab.image }}"/>
                    </div>
                </div>

                {% if tab.benefits %}
                <!-- Bottom section: Core Benefits & Features -->
                <div>
                    <h4 class="font-mono text-xs text-primary mb-8 tracking-widest uppercase text-left">Core Benefits &amp; Features //</h4>
                    <div class="tech-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4">
                        {% for benefit in tab.benefits %}
                        <div class="tech-grid-cell flex flex-col justify-start">
                            <div class="font-mono text-[10px] text-primary uppercase tracking-widest mb-4">
                                Benefit // {{ benefit.title }}
                            </div>
                            <p class="font-body-md text-xs text-secondary leading-relaxed">{{ benefit.description }}</p>
                        </div>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </section>

    <!-- Services Grid -->
    <section class="bg-surface-container-low py-20 border-t border-b border-outline-variant/20">
        <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
            <div class="mb-16 reveal">
                <span class="font-mono text-xs text-primary uppercase tracking-widest mb-3 block">02 // Specialized Programs</span>
                <h2 class="font-headline-lg text-3xl md:text-headline-lg text-slate-deep font-bold">{{ services.title }}</h2>
                <p class="font-body-md text-body-md text-secondary max-w-2xl mt-4 leading-relaxed">{{ services.description }}</p>
            </div>
            
            <div class="tech-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
                {% for svc in services.list %}
                {% if svc.special %}
                <!-- Special Big Feature Card -->
                <div class="tech-grid-cell lg:col-span-2 flex flex-col justify-between bg-slate-deep text-pure-white relative min-h-[400px]">
                    <div>
                        <span class="font-mono text-[10px] text-primary-fixed uppercase tracking-widest mb-3 block">Special Operation // {{ svc.badge }}</span>
                        <h3 class="font-headline-md text-2xl text-pure-white mb-4 font-bold">{{ svc.title }}</h3>
                        <p class="font-body-md text-sm text-surface-variant/80 leading-relaxed mb-6">
                            {{ svc.description }}
                        </p>
                    </div>
                    <div class="flex flex-wrap items-center justify-between border-t border-white/10 pt-4 mt-auto">
                        <span class="font-mono text-[9px] text-primary-fixed uppercase tracking-wider">{{ svc.status }}</span>
                        <span class="font-mono text-[9px] text-eco-growth uppercase tracking-wider flex items-center gap-1">
                            <span class="w-1.5 h-1.5 bg-eco-growth rounded-full inline-block"></span>
                            {{ svc.audit }}
                        </span>
                    </div>
                </div>
                {% else %}
                <!-- Regular Service Card -->
                <div class="tech-grid-cell flex flex-col justify-between">
                    <div>
                        <span class="font-mono text-[10px] text-primary uppercase tracking-widest mb-3 block">Service //</span>
                        <h3 class="font-headline-md text-lg text-slate-deep mb-3 font-bold">{{ svc.title }}</h3>
                        <p class="font-body-md text-sm text-secondary leading-relaxed mb-6">{{ svc.description }}</p>
                    </div>
                    {% if svc.image %}
                    <div class="w-full h-44 border border-outline-variant/20 overflow-hidden mt-4">
                        <img class="w-full h-full object-cover" alt="{{ svc.title }}" src="{{ svc.image }}"/>
                    </div>
                    {% endif %}
                </div>
                {% endif %}
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Delivery Process Timeline (Flowchart matrix grid) -->
    <section class="py-20 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
        <div class="mb-16 reveal">
            <span class="font-mono text-xs text-primary uppercase tracking-widest mb-3 block">03 // Implementation Flow</span>
            <h2 class="font-headline-lg text-3xl md:text-headline-lg text-slate-deep font-bold">{{ timeline.title }}</h2>
            <p class="font-body-md text-body-md text-secondary max-w-2xl mt-4 leading-relaxed">{{ timeline.description }}</p>
        </div>
        
        <div class="tech-grid grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5">
            {% for step in timeline.steps %}
            <div class="tech-grid-cell flex flex-col justify-start">
                <div class="font-mono text-xs text-primary uppercase tracking-widest mb-4">
                    [Step {{ step.number }}] // {{ step.title }}
                </div>
                <p class="font-body-md text-xs text-secondary leading-relaxed">{{ step.description }}</p>
            </div>
            {% endfor %}
        </div>
    </section>
</main>

<script>
    function switchTab(tabId) {
        const activeClass = 'tab-active';
        const inactiveClass = 'tab-inactive';
        
        const wrapper = document.querySelector('.tab-content-wrapper');
        const currentActivePane = document.querySelector('.tab-content:not(.hidden)');
        const nextPane = document.getElementById(tabId);
        
        if (!nextPane || currentActivePane === nextPane) return;
        
        document.querySelectorAll('#solutions-tabs button').forEach(button => {
            button.classList.remove(activeClass);
            button.classList.add(inactiveClass);
        });
        const activeBtn = document.getElementById(`btn-${tabId}`);
        if (activeBtn) {
            activeBtn.classList.remove(inactiveClass);
            activeBtn.classList.add(activeClass);
        }

        wrapper.style.transition = 'height 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
        wrapper.style.willChange = 'height';

        if (currentActivePane) {
            const currentHeight = wrapper.offsetHeight;
            wrapper.style.height = currentHeight + 'px';
            void wrapper.offsetHeight;

            currentActivePane.classList.remove('active-pane');
            currentActivePane.classList.add('hidden');
        }

        nextPane.classList.remove('hidden');
        const targetHeight = nextPane.offsetHeight;

        wrapper.style.height = targetHeight + 'px';

        setTimeout(() => {
            nextPane.classList.add('active-pane');
        }, 50);

        const handleTransitionEnd = (e) => {
            if (e.target === wrapper && e.propertyName === 'height') {
                wrapper.style.height = 'auto';
                wrapper.style.transition = '';
                wrapper.style.willChange = '';
                wrapper.removeEventListener('transitionend', handleTransitionEnd);
            }
        };
        wrapper.addEventListener('transitionend', handleTransitionEnd);
    }

    function initTabFromUrl() {
        const urlParams = new URLSearchParams(window.location.search);
        const tabParam = urlParams.get('tab');
        const validTabs = ['on-grid', 'off-grid', 'zero-invest', 'commercial', 'smart-seru'];
        
        if (tabParam && validTabs.includes(tabParam)) {
            setTimeout(() => {
                switchTab(tabParam);
            }, 50);
        }
    }

    if (document.readyState === 'loading') {
        window.addEventListener('DOMContentLoaded', initTabFromUrl);
    } else {
        initTabFromUrl();
    }
</script>
