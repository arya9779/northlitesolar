---
layout: "base.njk"
---
<main class="pt-[72px] md:pt-[80px] bg-background">

    <!-- Hero Image Banner -->
    <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-16 reveal">
        <div class="relative w-full h-[40vh] md:h-[50vh] overflow-hidden border border-outline-variant/30">
            <img alt="Solar Power Grid Hero Image" class="absolute inset-0 w-full h-full object-cover" src="{{ hero.image }}"/>
            <div class="absolute inset-0 bg-slate-deep/50 flex items-center justify-center p-6 md:p-8">
                <h1 class="font-display-lg text-headline-lg-mobile md:text-display-lg text-pure-white text-center max-w-4xl font-bold tracking-tight">
                    {{ hero.title }}
                </h1>
            </div>
        </div>
    </section>

    <!-- CEO Mission Statement & Quote (Overhaul) -->
    <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-24 reveal">
        <div class="border-t border-b border-outline-variant/30 py-16 flex flex-col items-start max-w-4xl mx-auto">
            <span class="font-mono text-xs text-primary uppercase tracking-widest mb-6">CEO Statement //</span>
            <blockquote class="font-display-lg text-[22px] md:text-[28px] text-slate-deep italic leading-relaxed font-semibold mb-8">
                "{{ quote.text }}"
            </blockquote>
            <footer class="font-mono text-xs uppercase tracking-wider text-secondary">
                <strong class="text-slate-deep block mb-1 font-bold">{{ quote.author }}</strong>
                {{ quote.role }}
            </footer>
        </div>
    </section>

    <!-- Specialized Divisions Section -->
    <section id="divisions" class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-24">
        <div class="mb-16 reveal">
            <span class="font-mono text-xs text-primary uppercase tracking-widest mb-3 block">01 // Divisions</span>
            <h2 class="font-headline-lg text-3xl md:text-headline-lg text-slate-deep font-bold">{{ divisions.title }}</h2>
            <p class="font-body-lg text-body-md text-secondary max-w-2xl mt-4 leading-relaxed">{{ divisions.description }}</p>
        </div>
        
        <div class="tech-grid grid grid-cols-1 md:grid-cols-3">
            {% for div in divisions.list %}
            <div class="tech-grid-cell flex flex-col justify-between">
                <div>
                    <div class="font-mono text-[10px] text-primary uppercase tracking-widest mb-6">
                        Division // {{ div.title }}
                    </div>
                    <p class="font-body-md text-sm text-secondary leading-relaxed mb-6">
                        {{ div.description }}
                    </p>
                    <ul class="space-y-2 font-mono text-[10px] uppercase tracking-wider text-slate-deep border-t border-outline-variant/20 pt-4 mt-auto">
                        {% for point in div.points %}
                        <li class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-sm">arrow_right</span>
                            <span>{{ point }}</span>
                        </li>
                        {% endfor %}
                    </ul>
                </div>
                {% if div.image %}
                <div class="h-32 w-full border border-outline-variant/20 overflow-hidden mt-6">
                    <img alt="{{ div.title }}" class="w-full h-full object-cover" src="{{ div.image }}"/>
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </section>

    <!-- Meet Our Team Section -->
    <section id="team" class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mb-24 reveal">
        <div class="mb-16">
            <span class="font-mono text-xs text-primary uppercase tracking-widest mb-3 block">02 // Team Directory</span>
            <h2 class="font-headline-lg text-3xl md:text-headline-lg text-slate-deep font-bold">{{ team.title }}</h2>
            <p class="font-body-lg text-body-md text-secondary max-w-2xl mt-4 leading-relaxed">{{ team.description }}</p>
        </div>
        
        <div class="mb-16">
            <h3 class="font-mono text-sm uppercase tracking-widest text-slate-deep mb-8 border-b border-outline-variant/30 pb-3 flex items-center gap-2 font-bold">
                [EX] // Executive Directors
            </h3>
            <div class="tech-grid grid grid-cols-1 md:grid-cols-2">
                {% for member in team.executives %}
                <div class="tech-grid-cell flex flex-col md:flex-row gap-6 items-start justify-between">
                    <div class="flex-grow">
                        <span class="font-mono text-[10px] text-primary uppercase tracking-widest mb-2 block">{{ member.role }}</span>
                        <h4 class="font-headline-md text-lg text-slate-deep font-bold mb-3">{{ member.name }}</h4>
                        <p class="font-body-md text-sm text-secondary leading-relaxed mb-4">{{ member.bio }}</p>
                        <a href="{{ member.linkedin }}" target="_blank" class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-wider text-primary hover:text-slate-deep">
                            LinkedIn Profile
                            <span class="material-symbols-outlined text-sm">open_in_new</span>
                        </a>
                    </div>
                    {% if member.image %}
                    <div class="w-28 h-28 border border-outline-variant/20 overflow-hidden flex-shrink-0 bg-slate-100">
                        <img alt="{{ member.name }}" class="w-full h-full object-cover object-top" src="{{ member.image }}"/>
                    </div>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>

        <div>
            <h3 class="font-mono text-sm uppercase tracking-widest text-slate-deep mb-8 border-b border-outline-variant/30 pb-3 flex items-center gap-2 font-bold">
                [MG] // Management Team
            </h3>
            <div class="tech-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
                {% for member in team.management %}
                <div class="tech-grid-cell flex flex-col justify-between">
                    <div>
                        <span class="font-mono text-[9px] text-primary uppercase tracking-widest mb-2 block">{{ member.role }}</span>
                        <h4 class="font-headline-md text-base text-slate-deep font-bold mb-3">{{ member.name }}</h4>
                        <p class="font-body-md text-xs text-secondary leading-relaxed mb-4">{{ member.bio }}</p>
                    </div>
                    <div class="flex justify-between items-center mt-auto pt-4 border-t border-outline-variant/25">
                        <a href="{{ member.linkedin }}" target="_blank" class="inline-flex items-center gap-1.5 font-mono text-[9px] uppercase tracking-wider text-primary hover:text-slate-deep">
                            LinkedIn
                            <span class="material-symbols-outlined text-xs">open_in_new</span>
                        </a>
                        {% if member.image %}
                        <div class="w-12 h-12 border border-outline-variant/20 overflow-hidden">
                            <img alt="{{ member.name }}" class="w-full h-full object-cover object-top" src="{{ member.image }}"/>
                        </div>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>
</main>
