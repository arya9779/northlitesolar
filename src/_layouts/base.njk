                <span class="font-button text-button">Foundation</span>
            </a>
            <a class="flex items-center gap-4 px-4 py-3 rounded-xl transition-colors drawer-link-stagger {% if '/events' in page.url %}bg-primary-container/20 text-primary font-bold{% else %}text-secondary hover:bg-surface-container{% endif %}" href="/events">
                <span class="material-symbols-outlined">event</span>
