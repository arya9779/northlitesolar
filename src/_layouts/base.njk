                                "h3": { "fontFamily": "Montserrat, sans-serif", "color": "#1E293B" },
                                "h4": { "fontFamily": "Montserrat, sans-serif", "color": "#1E293B" },
                                "p": { "fontFamily": "Outfit, sans-serif" },
                                "a": { "color": "#795900", "&:hover": { "color": "#f9bd22" } }
                            }
                        }
                    },
                    "fontSize": {
                        "label-caps": ["12px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "500" }],
                        "headline-md": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                        "button": ["16px", { "lineHeight": "20px", "fontWeight": "600" }],
                        "body-md": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "body-lg": ["18px", { "lineHeight": "28px", "fontWeight": "400" }],
                        "headline-lg-mobile": ["32px", { "lineHeight": "40px", "fontWeight": "700" }],
                        "display-lg": ["64px", { "lineHeight": "72px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "headline-lg": ["40px", { "lineHeight": "48px", "letterSpacing": "-0.01em", "fontWeight": "700" }]
