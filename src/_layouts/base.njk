                        "on-tertiary-container": "#0053a1",
                        "on-secondary": "#ffffff",
                        "on-surface-variant": "#4f4633",
                        "surface-container-high": "#e6e8ea",
                        "eco-growth": "#10B981",
                        "slate-deep": "#1E293B",
                        "on-error-container": "#93000a",
                        "secondary-fixed-dim": "#b8c7e5",
                        "tertiary": "#005eb5",
                        "surface-container-lowest": "#ffffff",
                        "primary": "#795900",
                        "surface-container-low": "#f2f4f6",
                        "background": "#f7f9fb",
                        "on-primary-container": "#6c4f00",
                        "secondary": "#515f79",
                        "surface-variant": "#e0e3e5",
                        "primary-fixed-dim": "#f9bd22",
                        "surface": "#f7f9fb",
                        "secondary-container": "#d2e0ff",
                        "outline-variant": "#d3c5ac",
                        "on-tertiary-fixed-variant": "#00468a",
                        "inverse-surface": "#2d3133",
                        "on-tertiary": "#ffffff",
                        "on-primary-fixed": "#261a00",
                        "outline": "#817661",
                        "error-container": "#ffdad6",
                        "on-secondary-fixed-variant": "#394760",
                        "surface-container-highest": "#e0e3e5",
                        "on-primary": "#ffffff",
                        "tertiary-container": "#abc9ff",
                        "surface-dim": "#d8dadc",
                        "tertiary-fixed": "#d6e3ff",
                        "surface-container": "#eceef0",
                        "on-secondary-fixed": "#0c1c33",
                        "inverse-on-surface": "#eff1f3",
                        "solar-energy": "#FF6900",
                        "on-secondary-container": "#55637e",
                        "on-background": "#191c1e",
                        "error": "#ba1a1a",
                        "pure-white": "#FFFFFF",
                        "on-error": "#ffffff",
                        "surface-bright": "#f7f9fb"
