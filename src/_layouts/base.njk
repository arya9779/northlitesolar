<body class="bg-background text-on-surface font-body-md antialiased {% if transparent_header %}has-transparent-header{% endif %}">

    <div id="scroll-progress"></div>
    <!-- TopNavBar (Shared Component) -->
    <header id="site-header" class="fixed top-0 w-full z-50 transition-all duration-300 py-4">
        <div class="flex justify-between items-center px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
            <!-- Mobile Menu Toggle -->
            <button aria-label="Open Navigation Menu" class="lg:hidden transition-colors flex items-center justify-center p-1" id="drawer-open-btn">
                <span class="material-symbols-outlined text-[28px]">menu</span>
            </button>

            <!-- Brand Logo -->
            <a href="/" class="flex items-center">
                <img alt="NorthLite Solar Logo" class="brand-logo-img h-9 md:h-10 w-auto transition-all duration-300" src="/assets/images/logo.png"/>
            </a>

            <!-- Desktop Links -->
            <nav class="hidden lg:flex items-center space-x-6 xl:space-x-8">
                <a class="nav-link font-button text-button transition-all duration-300 pb-1 border-b-2 {% if page.url == '/' %}active-link border-current{% else %}border-transparent{% endif %}" href="/">Home</a>
                <a class="nav-link font-button text-button transition-all duration-300 pb-1 border-b-2 {% if '/about' in page.url %}active-link border-current{% else %}border-transparent{% endif %}" href="/about">About Us</a>
                
                <div class="relative group">
                    <a class="nav-link font-button text-button transition-all duration-300 pb-1 border-b-2 {% if '/solutions' in page.url %}active-link border-current{% else %}border-transparent{% endif %} flex items-center gap-1" href="/solutions">
                        Solutions
                        <span class="material-symbols-outlined text-[16px]">expand_more</span>
                    </a>
                    <div class="absolute left-0 mt-2 w-56 bg-surface shadow-lg rounded-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 z-50 border border-surface-variant">
                        <a href="/solutions?tab=commercial" class="block px-4 py-3 text-sm text-secondary hover:bg-surface-container hover:text-primary transition-colors first:rounded-t-xl">Commercial & Industrial</a>
                        <a href="/solutions?tab=residential" class="block px-4 py-3 text-sm text-secondary hover:bg-surface-container hover:text-primary transition-colors">Residential Solar</a>
                        <a href="/solutions?tab=diaspora" class="block px-4 py-3 text-sm text-secondary hover:bg-surface-container hover:text-primary transition-colors">Diaspora Solutions</a>
                        <a href="/solutions?tab=investment" class="block px-4 py-3 text-sm text-secondary hover:bg-surface-container hover:text-primary transition-colors last:rounded-b-xl">Renewable Energy Investment</a>
                    </div>
                </div>

                <a class="nav-link font-button text-button transition-all duration-300 pb-1 border-b-2 {% if '/impact' in page.url %}active-link border-current{% else %}border-transparent{% endif %}" href="/impact">Impact</a>
                <a class="nav-link font-button text-button transition-all duration-300 pb-1 border-b-2 {% if '/foundation' in page.url %}active-link border-current{% else %}border-transparent{% endif %}" href="/foundation">Foundation</a>
                <a class="nav-link font-button text-button transition-all duration-300 pb-1 border-b-2 {% if '/events' in page.url %}active-link border-current{% else %}border-transparent{% endif %}" href="/events">Events</a>
                <a class="nav-link font-button text-button transition-all duration-300 pb-1 border-b-2 {% if '/news' in page.url %}active-link border-current{% else %}border-transparent{% endif %}" href="/news">News</a>
                <a class="nav-link font-button text-button transition-all duration-300 pb-1 border-b-2 {% if '/contact' in page.url %}active-link border-current{% else %}border-transparent{% endif %}" href="/contact">Contact</a>
            </nav>

            <!-- CTA Quote Button -->
            <a href="/contact#contact-form" class="bg-primary-container text-slate-deep font-button text-[12px] md:text-button px-3 md:px-6 py-2 md:py-3 rounded-lg hover-scale active:scale-95 transition-transform text-center shadow-sm btn-magnetic whitespace-nowrap">
                Get a Quote
            </a>
        </div>
    </header>

